{
  "manifest_version": 3,
  "name": "PineSnap Bilibili Capture",
  "version": "0.1.0",
  "description": "Capture Bilibili subtitles and send them to PineSnap.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "https://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": [
        "shared/runtime.js",
        "shared/extractors/bilibili-full-subtitle.js",
        "shared/extractor-registry.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "PineSnap Capture"
  }
}
