# 环境变量模板（可提交）
#
# 约定：
# - `SUPABASE_URL` / `NEXT_PUBLIC_SUPABASE_URL` 必须是 Supabase 项目 HTTP URL（https://...）
# - `DATABASE_URL` / `DIRECT_URL` 必须是 Postgres 连接串（postgresql://...）
# - `NEXT_PUBLIC_*` 会暴露给浏览器；严禁放置 service role 等敏感密钥

## Database (Postgres)

# Prisma Runtime / Adapter 使用（服务端运行时）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Prisma Migrate 使用（建议为 Supabase 的 direct connection，并带 sslmode=require）
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

## Supabase (HTTP project URL + keys)

# 服务端使用（middleware / server components / admin client）
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# 客户端使用（浏览器）
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

## File Storage

# 可选：local | supabase（默认：若存在 SUPABASE_SERVICE_ROLE_KEY 则为 supabase，否则为 local）
FILE_STORAGE_DRIVER="supabase"
SUPABASE_STORAGE_BUCKET="uploads"
SUPABASE_SIGNED_URL_TTL_SECONDS="300"

