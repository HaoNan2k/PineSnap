// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        String   @id @default(uuid(7))
  title     String   @default("New Chat")
  userId    String
  // Idempotency key for the first user message (used for lazy-create retries)
  firstClientMessageId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@index([userId])
  @@unique([userId, firstClientMessageId])
}

model Message {
  id             String       @id @default(uuid(7))
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           Role     @default(user)
  // Idempotency key from the client for this message (used to dedupe retries)
  clientMessageId String?
  content        String       @db.Text
  parts          Json         @default("[]") // Structured content
  parentMessageId String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@unique([conversationId, clientMessageId])
}

enum Role {
  user
  assistant
  system
}
