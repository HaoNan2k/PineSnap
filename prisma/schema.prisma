generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                   String    @id @default(uuid(7))
  title                String    @default("New Chat")
  userId               String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  firstClientMessageId String?
  deletedAt            DateTime?
  messages             Message[]
  learningConnections  LearningConversation[]

  @@unique([userId, firstClientMessageId])
  @@index([userId])
}

model Message {
  id              String       @id @default(uuid(7))
  conversationId  String
  content         String
  parentMessageId String?
  createdAt       DateTime     @default(now())
  role            Role         @default(user)
  clientMessageId String?
  parts           Json         @default("[]")
  deletedAt       DateTime?
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, clientMessageId])
  @@index([conversationId])
}

model CaptureToken {
  id         String   @id @default(uuid(7))
  userId     String
  tokenHash  String   @unique
  label      String?
  scopes     String[] @default([])
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

model CaptureAuthCode {
  id            String   @id @default(uuid(7))
  userId        String
  codeHash      String   @unique
  codeChallenge String
  state         String
  redirectUri   String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Resource {
  id         String   @id @default(uuid(7))
  userId     String
  type       String
  sourceType CaptureSourceType @default(bilibili)
  sourceUrl  String?
  canonicalUrl String?
  sourceFingerprint String?
  title      String
  externalId String?
  content    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  learnings  LearningResource[]
  captureJobs CaptureJob[]
  artifacts  CaptureArtifact[]

  @@index([userId])
  @@index([type, externalId])
  @@index([userId, sourceType])
  @@index([userId, sourceFingerprint])
}

model CaptureJob {
  id               String           @id @default(uuid(7))
  userId           String
  resourceId       String
  sourceType       CaptureSourceType
  jobType          CaptureJobType
  executionMode    CaptureExecutionMode @default(ASYNC)
  captureRequestId String
  status           CaptureJobStatus @default(PENDING)
  stage            CaptureJobStage?
  inputContext     Json
  attempt          Int              @default(0)
  maxAttempts      Int              @default(3)
  errorCode        String?
  errorMessage     String?
  superseded       Boolean          @default(false)
  supersededByJobId String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  resource         Resource         @relation(fields: [resourceId], references: [id])
  artifacts        CaptureArtifact[]

  @@index([userId])
  @@index([resourceId, createdAt])
  @@index([resourceId, superseded, createdAt])
  @@unique([userId, sourceType, captureRequestId])
}

model CaptureArtifact {
  id           String              @id @default(uuid(7))
  resourceId   String
  jobId        String
  kind         CaptureArtifactKind
  language     String?
  format       CaptureArtifactFormat?
  isPrimary    Boolean             @default(false)
  qualityScore Float?
  content      Json
  createdAt    DateTime            @default(now())
  resource     Resource            @relation(fields: [resourceId], references: [id])
  job          CaptureJob          @relation(fields: [jobId], references: [id])

  @@index([resourceId, createdAt])
  @@index([jobId, createdAt])
  @@index([resourceId, kind, language, isPrimary])
}

model Learning {
  id            String   @id @default(uuid(7))
  plan          String?  @db.Text
  clarify       Json?    @db.JsonB
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  resources     LearningResource[]
  conversations LearningConversation[]
}

model LearningResource {
  learningId String
  resourceId String
  createdAt  DateTime @default(now())
  learning   Learning @relation(fields: [learningId], references: [id])
  resource   Resource @relation(fields: [resourceId], references: [id])

  @@id([learningId, resourceId])
}

model LearningConversation {
  learningId     String
  conversationId String
  createdAt      DateTime     @default(now())
  learning       Learning     @relation(fields: [learningId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@id([learningId, conversationId])
  @@index([conversationId])
}

enum Role {
  user
  assistant
  system
  tool
}

enum CaptureSourceType {
  bilibili
  wechat_article
  web_page
  youtube
  xiaohongshu
}

enum CaptureJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum CaptureArtifactKind {
  official_subtitle
  asr_transcript
  summary
  extracted_text
}

enum CaptureArtifactFormat {
  cue_lines
  json
  plain_text
  markdown
  binary_ref
}

enum CaptureJobType {
  subtitle_fetch
  audio_transcribe
  web_extract
  article_extract
  summary_generate
  media_ingest
}

enum CaptureExecutionMode {
  INLINE
  ASYNC
}

enum CaptureJobStage {
  QUEUED
  CLAIMED
  PERSISTING_ARTIFACT
  COMPLETED
  FAILED
  CANCELLED
}
