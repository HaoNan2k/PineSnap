generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                   String    @id @default(uuid(7))
  title                String    @default("New Chat")
  userId               String
  kind                 ConversationKind @default(canvas)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  firstClientMessageId String?
  deletedAt            DateTime?
  messages             Message[]
  learningConnections  LearningConversation[]

  @@unique([userId, firstClientMessageId])
  @@index([userId])
}

model Message {
  id                      String       @id @default(uuid(7))
  conversationId          String
  parentMessageId         String?
  createdAt               DateTime     @default(now())
  role                    Role         @default(user)
  clientMessageId         String?
  parts                   Json         @default("[]")
  deletedAt               DateTime?
  anchoredCanvasMessageId String?
  conversation            Conversation @relation(fields: [conversationId], references: [id])
  anchoredCanvasMessage   Message?     @relation("AnchoredTo", fields: [anchoredCanvasMessageId], references: [id])
  anchoredChats           Message[]    @relation("AnchoredTo")

  @@unique([conversationId, clientMessageId])
  @@index([conversationId])
  @@index([anchoredCanvasMessageId])
}

model CaptureToken {
  id         String   @id @default(uuid(7))
  userId     String
  tokenHash  String   @unique
  label      String?
  scopes     String[] @default([])
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

model CaptureAuthCode {
  id            String   @id @default(uuid(7))
  userId        String
  codeHash      String   @unique
  codeChallenge String
  state         String
  redirectUri   String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Resource {
  id         String            @id @default(uuid(7))
  userId     String
  sourceType CaptureSourceType @default(bilibili)
  canonicalUrl String
  sourceFingerprint String?
  title      String
  thumbnailUrl String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  learnings  LearningResource[]
  captureJobs CaptureJob[]

  @@index([userId])
  @@index([userId, sourceType])
  @@index([userId, sourceFingerprint])
}

model CaptureJob {
  id               String           @id @default(uuid(7))
  resourceId       String
  sourceType       CaptureSourceType
  jobType          CaptureJobType
  executionMode    CaptureExecutionMode @default(ASYNC)
  captureRequestId String
  status           CaptureJobStatus @default(PENDING)
  stage            CaptureJobStage?
  inputContext     Json
  attempt          Int              @default(0)
  maxAttempts      Int              @default(3)
  errorCode        String?
  errorMessage     String?
  superseded       Boolean          @default(false)
  supersededByJobId String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  resource         Resource         @relation(fields: [resourceId], references: [id])
  artifacts        CaptureArtifact[]
  supersededByJob  CaptureJob?      @relation("CaptureJobSupersede", fields: [supersededByJobId], references: [id], onDelete: SetNull)
  supersededJobs   CaptureJob[]     @relation("CaptureJobSupersede")

  @@index([resourceId, createdAt])
  @@index([resourceId, superseded, createdAt])
  @@unique([resourceId, captureRequestId])
}

model CaptureArtifact {
  id           String              @id @default(uuid(7))
  jobId        String
  kind         CaptureArtifactKind
  language     String?
  format       CaptureArtifactFormat?
  schemaVersion Int                @default(1)
  isPrimary    Boolean             @default(false)
  qualityScore Float?
  content      Json
  createdAt    DateTime            @default(now())
  job          CaptureJob          @relation(fields: [jobId], references: [id])

  @@index([jobId, createdAt])
  @@index([jobId, kind, language, isPrimary])
}

model Learning {
  id            String   @id @default(uuid(7))
  plan          String?  @db.Text
  clarify       Json?    @db.JsonB
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  resources     LearningResource[]
  conversations LearningConversation[]
  conceptsCovered ConceptCoverage[]
}

model ConceptCoverage {
  id         String   @id @default(uuid(7))
  learningId String
  concept    String
  coveredAt  DateTime @default(now())
  learning   Learning @relation(fields: [learningId], references: [id])

  @@unique([learningId, concept])
  @@index([learningId])
}

model LearningResource {
  learningId String
  resourceId String
  createdAt  DateTime @default(now())
  learning   Learning @relation(fields: [learningId], references: [id])
  resource   Resource @relation(fields: [resourceId], references: [id])

  @@id([learningId, resourceId])
}

model LearningConversation {
  learningId     String
  conversationId String
  createdAt      DateTime     @default(now())
  learning       Learning     @relation(fields: [learningId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@id([learningId, conversationId])
  @@index([conversationId])
}

enum Role {
  user
  assistant
  system
  tool
}

enum ConversationKind {
  canvas
  chat
}

enum CaptureSourceType {
  bilibili
  wechat_article
  web_page
  youtube
  xiaohongshu
  douyin
}

enum CaptureJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum CaptureArtifactKind {
  official_subtitle
  asr_transcript
  summary
  extracted_text
}

enum CaptureArtifactFormat {
  cue_lines
  json
  plain_text
  markdown
  binary_ref
}

enum CaptureJobType {
  subtitle_fetch
  audio_transcribe
  web_extract
  article_extract
  summary_generate
  media_ingest
}

enum CaptureExecutionMode {
  INLINE
  ASYNC
}

enum CaptureJobStage {
  QUEUED
  CLAIMED
  PERSISTING_ARTIFACT
  COMPLETED
  FAILED
  CANCELLED
}
